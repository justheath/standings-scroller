---
// src/pages/index.astro
import { tournaments, siteConfig } from '../config/tournaments';
import '../styles/hub.css'; // SCALED: Imports the decoupled hub layout styles
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteConfig.tabName}</title>
  </head>
  <body>
    <div class="hub-container">
      <h1>{siteConfig.pageTitle}</h1>
      <div class="subtitle">Select an active tournament to launch the leaderboard</div>
      <div class="subtitle2">Scores may take up to 5 minutes to update</div>
      
      <div class="tournament-grid">
        {tournaments.map((tournament) => (
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/standings/${tournament.slug}`} class="tournament-card">
            <div class="card-info">
              <h2>{tournament.name}</h2>
              <p>{tournament.description}</p>
              
              <!-- TOURNAMENT METADATA CLUSTER -->
              <div class="metadata-row">
                <!-- Venue Location -->
                <div class="meta-item">
                  <span class="meta-label">VENUE:</span>
                  <span class="meta-value">{tournament.location}</span>
                </div>

                <!-- Schedule Range Badge List -->
                <div class="meta-item">
                  <span class="meta-label">SCHEDULE:</span>
                  {Array.isArray(tournament.dates) ? (
                    <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                      {tournament.dates.map((date) => (
                        <span class="meta-value">{date}</span>
                      ))}
                    </div>
                  ) : (
                    <span class="meta-value">{tournament.dates}</span>
                  )}
                </div>
              </div>

            </div>
            <div class="view-ticker-badge">View Leaderboard</div>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>
