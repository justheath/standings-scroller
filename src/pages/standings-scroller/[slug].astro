---
// src/pages/standings/[slug].astro
import { parse } from 'csv-parse/sync';
import { tournaments } from '../../config/tournaments';
import BowlingLeaderboard from '../../components/BowlingLeaderboard.astro';

// 1. Instruct Astro to generate a route template instance for every entry in the config file
export async function getStaticPaths() {
  return tournaments.map((t) => ({
    params: { slug: t.slug },
    props: { tournament: t }
  }));
}

const { tournament } = Astro.props;

interface BowlingRow {
  id: number;
  rank: number;
  team: string;
  scratchTotal: number;
  handicapTotal: number;
  [key: string]: any;
}

let sanitizedData: BowlingRow[] = [];
let errorMessage = "";

try {
  // 2. Fetch the corresponding CSV file matching this exact route slug parameters
  const response = await fetch(tournament.csvUrl);
  
  if (!response.ok) {
    throw new Error(`Remote dataset unavailable. Server code: ${response.status}`);
  }

  const fileContent = await response.text();

  // 3. Parse tabular records
  const rawRecords = parse(fileContent, {
    columns: true,
    skip_empty_lines: true
  });

  // 4. Sanitize strings to integer datatypes
  sanitizedData = rawRecords.map((row: any, index: number) => {
    const sanitizedRow: BowlingRow = {
      id: index + 1,
      rank: Number(row.rank),
      team: row.team,
      scratchTotal: Number(row.scratchTotal),
      handicapTotal: Number(row.handicapTotal),
    };

    Object.keys(row).forEach((key) => {
      if (!['rank', 'team', 'scratchTotal', 'handicapTotal'].includes(key)) {
        sanitizedRow[key] = Number(row[key]);
      }
    });

    return sanitizedRow;
  });

} catch (error: any) {
  console.error(`Error loading standings for ${tournament.slug}:`, error.message);
  errorMessage = `Unable to fetch live data for "${tournament.name}". Please return to the hub or try again later.`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tournament.name} - Live Standings</title>
    <style>
      body { margin: 0; padding: 0; background: #09090e; color: #fff; font-family: sans-serif; }
      .error-boundary {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100vh;
        gap: 20px;
        font-family: monospace;
      }
      .error-text { font-size: 1.3rem; color: #ff2a74; text-transform: uppercase; text-align: center; max-width: 600px; padding: 0 20px; }
      .back-btn { background: transparent; border: 1px solid #00f0ff; color: #00f0ff; padding: 10px 20px; font-weight: bold; cursor: pointer; text-decoration: none; text-transform: uppercase; font-size: 0.85rem; border-radius: 4px; }
      .back-btn:hover { background: #00f0ff; color: #09090e; }
    </style>
  </head>
  <body>
    {errorMessage ? (
      <div class="error-boundary">
        <div class="error-text">{errorMessage}</div>
        <a href="/" class="back-btn">← Back</a>
      </div>
    ) : (
      <!-- Inject data into your existing separated layout code components -->
      <BowlingLeaderboard 
        data={sanitizedData} 
        tournamentName={tournament.name} 
        defaultPixelsPerSecond={45} 
        csvUrl={tournament.csvUrl}
      />
    )}
  </body>
</html>
