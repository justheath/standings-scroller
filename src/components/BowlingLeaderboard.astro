---
// Component Script (Server-side)
import '../styles/leaderboard.css'; 

interface RowData {
  id: string | number;
  rank: number;        
  team: string;          
  scratchTotal: number;  
  handicapTotal: number; 
  [key: string]: any;    
}

interface Props {
  data: RowData[];
  tournamentName?: string;     
  defaultPixelsPerSecond?: number; 
  rowHeightPx?: number;
  sortByRank?: 'asc' | 'desc';
  defaultHighScoreThreshold?: number;
}

const { 
  data = [], 
  tournamentName = "Championship Bowling Series", 
  defaultPixelsPerSecond = 45, 
  rowHeightPx = 98,            
  sortByRank = 'asc',
  defaultHighScoreThreshold = 250 
} = Astro.props;

// Sort data numerically by rank
const sortedData = [...data].sort((a, b) => {
  return sortByRank === 'asc' ? a.rank - b.rank : b.rank - a.rank;
});

// Isolate variable game columns
const allKeys = Array.from(new Set(data.flatMap(item => Object.keys(item))));
const dynamicKeys = allKeys.filter(key => !['id', 'team', 'rank', 'scratchTotal', 'handicapTotal'].includes(key));


// Duplicate data once for seamless continuous loop frame calculations
const loopingData = [...sortedData, ...sortedData];
---

<!-- Retro Bowling Alley Main Wrapper Framework -->
<div class="bowling-leaderboard-wrapper theme-neon" style={`--row-height: ${rowHeightPx}px;`}>
  
  <!-- LAYER 1: MANAGEMENT CONTROL BAR (Now at the absolute top) -->
  <div class="top-control-bar">
    <!-- SPEED CONTROLLER -->
    <div class="control-group">
      <span class="control-label">TICKER SPEED:</span>
      <button class="control-btn speed-btn" data-multiplier="0">PAUSE</button>
      <button class="control-btn speed-btn active" data-multiplier="1">1X</button>
      <button class="control-btn speed-btn" data-multiplier="2">2X</button>
      <button class="control-btn speed-btn" data-multiplier="3">3X</button>
    </div>

    <!-- HIGH SCORE ALERTS -->
    <div class="control-group">
      <label class="control-label" for="high-score-input">HIGH SCORE ALERT:</label>
      <input type="number" id="high-score-input" class="threshold-input" value={defaultHighScoreThreshold} min="0" max="300" placeholder="250" />
    </div>

    <!-- THEME OPTIONS -->
    <div class="control-group">
      <span class="control-label">BOARD THEME:</span>
      <button class="control-btn theme-btn active" data-theme="neon">NEON ARCADE</button>
      <button class="control-btn theme-btn" data-theme="cyberpunk">CYBERPUNK</button>
      <button class="control-btn theme-btn" data-theme="classic">CLASSIC ALLEY</button>
      <button class="control-btn theme-btn" data-theme="matrix">MATRIX</button>
    </div>
  </div>

  <!-- LAYER 2: TOURNAMENT BANNER HEADER -->
  <div class="tournament-title-banner">
    <h1 class="tournament-heading">{tournamentName}</h1>
  </div>

  <!-- LAYER 3: STICKY TABLE HEADER -->
  <div class="table-header grid-row-layout">
    <div class="rank-header-cell">Rank</div>
    <div class="team-header-cell">Team Name</div>
    
    <div class="dynamic-values games-flex-track">
      {dynamicKeys.map((key) => (
        <span class={`header-game-label game-${key}`}>{key.toUpperCase()}</span>
      ))}
    </div>
    
    <div class="total-column scratch-header">Scratch</div>
    <div class="total-column">Handicap</div>
  </div>

  <!-- LAYER 4: SCROLLING TRACK ENGINE -->
  <div class="autoscroll-container" data-base-speed={defaultPixelsPerSecond}>
    <div class="autoscroll-track">
      {loopingData.map((row) => (
        <div class="autoscroll-row grid-row-layout">
          
          <!-- COLUMN 1: Rank -->
          <div>
            <span class="rank-tag">#{row.rank}</span>
          </div>

          <!-- COLUMN 2: Team Name -->
          <div>
            <strong class="row-team-text">{row.team}</strong>
          </div>

          <!-- COLUMN 3: Dynamic Inner Game Array Tracks -->
          <div class="dynamic-values games-flex-track">
            {dynamicKeys.map((key) => {
              const score = row[key];
              const isHighScore = score >= defaultHighScoreThreshold; 
              return (
                score !== undefined && (
                  <span class={`variable-field game-score game-${key} ${isHighScore ? 'high-score-flash' : ''}`} data-score={score}>
                    {score}
                  </span>
                )
              );
            })}
          </div>

          <!-- COLUMN 4: Scratch Series Total -->
          <div class="total-column scratch-cell">
            <span class="scratch-total">{row.scratchTotal}</span>
          </div>

          <!-- COLUMN 5: Weighted Handicap Total -->
          <div class="total-column">
            <strong class="handicap-total">{row.handicapTotal}</strong>
          </div>

        </div>
      ))}
    </div>
  </div>
</div>

<script>
  import { initLeaderboard } from '../scripts/leaderboard.ts';
  initLeaderboard();
  document.addEventListener('astro:after-swap', initLeaderboard);
</script>
