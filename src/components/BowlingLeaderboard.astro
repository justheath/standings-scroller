---
// src/components/BowlingLeaderboard.astro
import "../styles/leaderboard.css";

interface RowData {
  id: string | number;
  rank: number;
  team: string;
  scratchTotal: number;
  handicapTotal: number;
  [key: string]: any;
}

interface Props {
  data: RowData[];
  tournamentName?: string;
  csvUrl: string;
  defaultPixelsPerSecond?: number;
  rowHeightPx?: number;
  sortByRank?: "asc" | "desc";
  defaultHighScoreThreshold?: number;
  scratchOnly?: boolean; // 🆕 Added to component prop interface
}

const {
  data = [],
  tournamentName = "Championship Bowling Series",
  csvUrl,
  defaultPixelsPerSecond = 100,
  rowHeightPx = 98,
  sortByRank = "asc",
  defaultHighScoreThreshold = 250,
  scratchOnly = false // 🆕 Defaults to false to protect your mixed baseline
} = Astro.props;

const sortedData = [...data].sort((a, b) => {
  return sortByRank === "asc" ? a.rank - b.rank : b.rank - a.rank;
});

const allKeys = Array.from(new Set(data.flatMap((item) => Object.keys(item))));
const dynamicKeys = allKeys.filter(
  (key) =>
    !["id", "team", "rank", "scratchTotal", "handicapTotal"].includes(key),
);
const loopingData = [...sortedData, ...sortedData];
---

<!-- 🆕 Conditionally appends the layout modifier class string directly to the layout shell -->
<div
  class={`bowling-leaderboard-wrapper theme-neon ${scratchOnly ? 'layout-scratch-only' : ''}`}
  style={`--row-height: ${rowHeightPx}px;`}
>
  <!-- TOP CONTROL DASHBOARD BAR -->
  <div class="top-control-bar">
    <div class="control-left-side">
      <div class="control-group">
        <a href={import.meta.env.BASE_URL} class="control-btn exit-hub-btn">← Back</a>
      </div>

      <div class="control-group">
        <span class="control-label">SPEED:</span>
        <button class="control-btn speed-btn" data-multiplier="0">PAUSE</button>
        <button class="control-btn speed-btn" data-multiplier="1">1X</button>
        <button class="control-btn speed-btn" data-multiplier="2">2X</button>
        <button class="control-btn speed-btn" data-multiplier="4">4X</button>
      </div>

      <div class="control-group">
        <label class="control-label" for="high-score-input">HIGH SCORE ALERT:</label>
        <input
          type="number"
          id="high-score-input"
          class="threshold-input"
          data-default-threshold={defaultHighScoreThreshold}
          min="0"
          max="300"
          placeholder="250"
        />
      </div>
    </div>
    <div class="control-group">
      <span class="control-label">THEME:</span>
      <button class="control-btn theme-btn" data-theme="neon">NEON ARCADE</button>
      <button class="control-btn theme-btn" data-theme="cyberpunk">CYBERPUNK</button>
      <button class="control-btn theme-btn" data-theme="classic">CLASSIC ALLEY</button>
      <button class="control-btn theme-btn" data-theme="matrix">MATRIX</button>
    </div>
  </div>

  <!-- BRAND BANNER -->
  <div class="tournament-title-banner">
    <h1 class="tournament-heading">{tournamentName}</h1>
  </div>

  <!-- TABLE GRID HEADERS -->
  <div class="table-header grid-row-layout">
    <div>Rank</div>
    <div>Team Name</div>
    <div class="dynamic-values games-flex-track">
      {
        dynamicKeys.map((key) => (
          <span class={`header-game-label game-${key}`}>
            {key.toUpperCase()}
          </span>
        ))
      }
    </div>
    <!-- 🆕 Renamed string header header dynamically if scratch only is running -->
    <div class="total-column scratch-header">{"Scratch"}</div>
    <!-- 🆕 Conditional evaluation logic lock wrapper -->
    {!scratchOnly && <div class="total-column">Handicap</div>}
  </div>

  <!-- SCROLLING ANIMATION TRACK -->
  <div
    class="autoscroll-container"
    data-base-speed={defaultPixelsPerSecond}
    data-csv-url={csvUrl}
  >
    <div class="autoscroll-track">
      {
        loopingData.map((row) => (
          <div class="autoscroll-row grid-row-layout">
            <div>
              <span class="rank-tag">#{row.rank}</span>
            </div>
            <div>
              <strong class="row-team-text">{row.team}</strong>
            </div>
            <div class="dynamic-values games-flex-track">
              {dynamicKeys.map((key) => {
                const score = row[key];
                return (
                  score !== undefined && (
                    <span
                      class={`variable-field game-score game-${key}`}
                      data-score={score}
                    >
                      {Number(score) === 0 ? ' - ' : score}
                    </span>
                  )
                );
              })}
            </div>
            <div class="total-column scratch-cell">
              <span class="scratch-total">{row.scratchTotal}</span>
            </div>
            <!-- 🆕 Conditional evaluation logic lock wrapper -->
            {!scratchOnly && (
              <div class="total-column">
                <strong class="handicap-total">{row.handicapTotal}</strong>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import { initLeaderboard } from "../scripts/leaderboard.ts";
  initLeaderboard();
  document.addEventListener("astro:after-swap", initLeaderboard);
</script>
